# Supabase PostgreSQL Connection String (usar conexão direta, ex: modo de transação/porta 5432 ou pooling 6543)
# Formato: postgresql://postgres.[username]:[password]@[host]:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.your-project-id:your-password@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Configuração do Servidor FastAPI (opcional)
PORT=8000
HOST=0.0.0.0
